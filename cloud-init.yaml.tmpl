#cloud-config
# Troy Server one-click deploy
# Renders on Ubuntu 24.04 LTS. Placeholders ({{...}}) are substituted by the deploy workflow.

package_update: true
package_upgrade: true

apt:
  sources:
    ondrej-php:
      source: "ppa:ondrej/php"

packages:
  - caddy
  - mariadb-server
  - php8.5-fpm
  - php8.5-mysql
  - php8.5-curl
  - php8.5-xml
  - php8.5-mbstring
  - php8.5-zip
  - php8.5-gd
  - php8.5-intl
  - unzip
  - curl
  - jq
  - ufw

write_files:
  - path: /etc/caddy/Caddyfile
    content: |
      {
          email {{ADMIN_EMAIL}}
      }

      {{DOMAIN}} {
          root * /var/www/html
          php_fastcgi unix//run/php/php8.5-fpm.sock
          file_server
          encode zstd gzip
      }

  - path: /root/install-troy.sh
    permissions: '0700'
    content: |
      #!/bin/bash
      set -euo pipefail

      DOMAIN="{{DOMAIN}}"
      ADMIN_EMAIL="{{ADMIN_EMAIL}}"
      ADMIN_USER="{{ADMIN_USER}}"
      ADMIN_PASSWORD='{{ADMIN_PASSWORD}}'
      SITE_TITLE="{{SITE_TITLE}}"
      PLUGIN_REPO="{{PLUGIN_REPO}}"
      DB_ROOT_PASSWORD='{{DB_ROOT_PASSWORD}}'
      DB_PASSWORD='{{DB_PASSWORD}}'

      mysql -uroot <<SQL
      ALTER USER 'root'@'localhost' IDENTIFIED BY '$DB_ROOT_PASSWORD';
      CREATE DATABASE IF NOT EXISTS wordpress CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
      CREATE USER IF NOT EXISTS 'wordpress'@'localhost' IDENTIFIED BY '$DB_PASSWORD';
      GRANT ALL PRIVILEGES ON wordpress.* TO 'wordpress'@'localhost';
      FLUSH PRIVILEGES;
      SQL

      curl -fsSL https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar -o /usr/local/bin/wp
      chmod +x /usr/local/bin/wp

      rm -rf /var/www/html
      mkdir -p /var/www/html
      chown -R www-data:www-data /var/www/html
      cd /var/www/html

      sudo -u www-data wp core download
      sudo -u www-data wp config create \
          --dbname=wordpress \
          --dbuser=wordpress \
          --dbpass="$DB_PASSWORD"
      sudo -u www-data wp core install \
          --url="https://$DOMAIN" \
          --title="$SITE_TITLE" \
          --admin_user="$ADMIN_USER" \
          --admin_password="$ADMIN_PASSWORD" \
          --admin_email="$ADMIN_EMAIL" \
          --skip-email

      RELEASE_JSON=$(curl -fsSL "https://api.github.com/repos/$PLUGIN_REPO/releases/latest")
      SERVER_ZIP_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | test("^troy-server-[0-9].*\\.zip$")) | .browser_download_url')
      CLIENT_ZIP_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | test("^troy-client-[0-9].*\\.zip$")) | .browser_download_url')
      for pair in "troy-server:$SERVER_ZIP_URL" "troy-client:$CLIENT_ZIP_URL"; do
          slug="${pair%%:*}"
          url="${pair#*:}"
          if [ -z "$url" ] || [ "$url" = "null" ]; then
              echo "Could not find $slug zip in latest release of $PLUGIN_REPO" >&2
              exit 1
          fi
          curl -fsSL "$url" -o "/tmp/$slug.zip"
          sudo -u www-data unzip -q -o "/tmp/$slug.zip" -d /var/www/html/wp-content/plugins/
          sudo -u www-data wp plugin activate "$slug"
      done

      # Caddy auto-provisions the Let's Encrypt cert on first request once DNS resolves to this box.
      systemctl enable --now caddy

      ufw allow OpenSSH
      ufw allow 80/tcp
      ufw allow 443/tcp
      ufw --force enable

      echo "Troy install complete. Admin: https://$DOMAIN/wp-admin"
      echo "Caddy will fetch the TLS cert automatically ~30s after your A record resolves."

runcmd:
  - bash /root/install-troy.sh 2>&1 | tee /var/log/troy-install.log
